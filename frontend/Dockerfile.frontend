# Use python slim image
FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the frontend code
COPY . .

# List files just to be safe (this will show in your logs)
RUN ls -la

# Expose Streamlit's default port
EXPOSE 8501

# Run Streamlit (Updated to look for app.py)
CMD ["streamlit", "run", "frontend/app_final.py", "--server.port=8501", "--server.address=0.0.0.0"]